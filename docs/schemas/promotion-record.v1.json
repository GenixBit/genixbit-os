{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GenixBitPromotionRecord",
  "type": "object",
  "required": [
    "schema_version",
    "package",
    "version",
    "from_channel",
    "to_channel",
    "promoter",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "package": { "type": "string" },
    "version": { "type": "string" },
    "from_channel": { "type": "string" },
    "to_channel": { "type": "string" },
    "promoter": { "type": "string" },
    "reviewer": { "type": "string" },
    "previous_snapshot": { "type": "string" },
    "timestamp": { "type": "string" },
    "validation_pr": { "type": "string" }
  }
}
